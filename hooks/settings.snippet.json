{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "__BIN__/claude-status hook idle" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "__BIN__/claude-status hook working" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          { "type": "command", "command": "__BIN__/claude-status hook working" }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          { "type": "command", "command": "__BIN__/claude-status hook attention" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "__BIN__/claude-status hook idle" }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          { "type": "command", "command": "__BIN__/claude-status hook idle" }
        ]
      }
    ]
  }
}
